const mcEras=["Todos","Barroco","Clásico","Romántico","Siglo XX","Contemporáneo"];
const mcEraClass={
  "Barroco":"mc-era-baroque",
  "Clásico":"mc-era-clasico",
  "Romántico":"mc-era-romantic",
  "Siglo XX":"mc-era-xx",
  "Contemporáneo":"mc-era-cont"
};

let mcSortKey="year", mcSortDir=1, mcActiveEra="Todos";

function mcBuildFilters(){
  const c=document.getElementById("mc-era-filters");
  mcEras.forEach(e=>{
    const b=document.createElement("button");
    b.className="mc-filter-btn"+(e==="Todos"?" mc-active":"");
    b.textContent=e;
    b.onclick=()=>{
      mcActiveEra=e;
      document.querySelectorAll(".mc-filter-btn").forEach(x=>x.classList.remove("mc-active"));
      b.classList.add("mc-active");
      mcRender();
    };
    c.appendChild(b);
  });
}

function mcSort(key){
  if(mcSortKey===key) mcSortDir*=-1;
  else{mcSortKey=key; mcSortDir=1;}
  document.querySelectorAll(".mc-table thead th").forEach(th=>th.classList.remove("mc-sorted"));
  ["title","composer","year","era","country"].forEach(k=>{
    const si=document.getElementById("mc-si-"+k);
    if(si){
      si.textContent=k===mcSortKey?(mcSortDir===1?"↑":"↓"):"↕";
      if(k===mcSortKey) si.closest("th").classList.add("mc-sorted");
    }
  });
  mcRender();
}

function mcRender(){
  const q=(document.getElementById("mc-search").value||"").toLowerCase();
  let rows=mcData.filter(d=>{
    const mq=!q||d.title.toLowerCase().includes(q)||d.composer.toLowerCase().includes(q);
    const me=mcActiveEra==="Todos"||d.era===mcActiveEra;
    return mq&&me;
  });
  rows.sort((a,b)=>{
    const av=mcSortKey==="year"?a.year:(a[mcSortKey]||"").toString().toLowerCase();
    const bv=mcSortKey==="year"?b.year:(b[mcSortKey]||"").toString().toLowerCase();
    return av<bv?-mcSortDir:av>bv?mcSortDir:0;
  });
  const tb=document.getElementById("mc-tbody");
  document.getElementById("mc-count").textContent=rows.length+" obra"+(rows.length!==1?"s":"");
  if(!rows.length){
    tb.innerHTML='<tr><td colspan="6" class="mc-no-results">Sin resultados</td></tr>';
    return;
  }
  tb.innerHTML=rows.map(d=>`<tr>
    <td class="mc-title">${d.title}</td>
    <td>${d.composer}</td>
    <td class="mc-year">${d.year}</td>
    <td><span class="mc-era-badge ${mcEraClass[d.era]||'mc-era-xx'}">${d.era}</span></td>
    <td style="font-size:0.8em">${d.country}</td>
    <td>${d.yt?`<a class="mc-yt-link" href="${d.yt}" target="_blank">▶ YouTube</a>`:'<span class="mc-no-link">—</span>'}</td>
  </tr>`).join("");
}

mcBuildFilters();
mcSort("year");
</script>



